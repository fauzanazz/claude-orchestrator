PROJECTS_CONFIG_PATH=../planner/projects.json
GITHUB_WEBHOOK_SECRET=whsec_...
GITHUB_USERNAME=your-username
CLAUDE_CODE_PATH=claude
MAX_CONCURRENT_AGENTS=2
AGENT_TIMEOUT_MS=1800000
POLL_INTERVAL_MS=30000
LOG_FLUSH_INTERVAL_MS=5000
PORT=7400

# Queue limits
# MAX_QUEUE_SIZE=20
# MAX_RETRIES_PER_RUN=3
# RETRY_COOLDOWN_MS=60000

# Notifications (optional — omit SLACK_WEBHOOK_URL to disable Slack)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# NOTIFY_POLL_INTERVAL_MS=120000

# Auto-fix (merge conflicts & CI failures)
MAX_FIX_RETRIES=3
# FIX_POLL_INTERVAL_MS=120000

# Database retention
# LOG_RETENTION_DAYS=30
# RUN_RETENTION_DAYS=90
# CLEANUP_INTERVAL_MS=86400000

# Memory agent (optional — omit to disable post-run documentation to obsidian-memory)
# Requires: obsidian-memory CLI installed, Obsidian running
# GEMINI_API_KEY=your-gemini-api-key
# MEMORY_PROJECT=claude-orchestrator

# Tunnel (optional — omit to disable webhook support)
# Only /webhook/github is exposed through the tunnel; dashboard stays localhost-only.
# TUNNEL_NAME=agent-orchestrator
# TUNNEL_HOSTNAME=agent-orch.yourdomain.com
